# 잇다랩 마스터 인프라 DB (itdalab-infra) — REST 읽기 전용
MASTER_DB_URL=
# 마스터 DB 익명 키 (읽기 전용)
MASTER_DB_ANON_KEY=
# 마스터 DB 서비스롤 키 (서버 전용, 절대 커밋 금지)
MASTER_DB_SERVICE_ROLE_KEY=

# 리붐단골 운영 DB (dangol)
DANGOL_DB_URL=
# dangol DB 서비스롤 키 (서버 전용, 절대 커밋 금지)
DANGOL_DB_SERVICE_ROLE_KEY=
# dangol DB 익명 키
DANGOL_DB_ANON_KEY=

# Sentry DSN (비어 있으면 no-op)
SENTRY_DSN=

# Client-side Supabase (anon key는 public by design)
NEXT_PUBLIC_DANGOL_DB_URL=
NEXT_PUBLIC_DANGOL_DB_ANON_KEY=

# SP-3 고객 PII 암호화 — 서버 전용, 값은 Vercel 대시보드에만 입력
# AES-256-GCM 키: 32바이트 랜덤 → base64 (값 절대 커밋 금지)
DANGOL_ENCRYPTION_SECRET=
# HMAC-SHA256 페퍼: 랜덤 문자열 (값 절대 커밋 금지)
DANGOL_HASH_SECRET=

# SP-5 Solapi 메시지 발송
# Solapi 웹훅 서명 검증 시크릿 — 서버 전용 (값 절대 커밋 금지)
SOLAPI_WEBHOOK_SECRET=
# Vercel Cron 보호 시크릿 — 서버 전용 (값 절대 커밋 금지)
CRON_SECRET=
# MOCK 모드: true = 실제 발송 없음 (테스트/개발 시 true 유지)
SOLAPI_MOCK=true
